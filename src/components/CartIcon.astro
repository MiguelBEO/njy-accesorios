<button id="cart-icon-btn" class="relative w-9 h-9 flex items-center justify-center rounded-full hover:bg-rose-50 transition-colors bg-transparent border-none cursor-pointer" aria-label="Abrir carrito">
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#8B3A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="9" cy="21" r="1"/>
    <circle cx="20" cy="21" r="1"/>
    <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
  </svg>
  <span id="cart-count-badge" class="absolute -top-0.5 -right-0.5 bg-gold-500 text-white text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center shadow-sm hidden">0</span>
</button>

<script>
  const btn = document.getElementById('cart-icon-btn')
  if (btn) {
    btn.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('njy-open-cart'))
    })
  }

  const badge = document.getElementById('cart-count-badge')
  if (badge) {
    const update = () => {
      try {
        const cart = JSON.parse(localStorage.getItem('njy-cart') || '[]')
        const count = cart.reduce((s: number, i: any) => s + (i.cantidad || 0), 0)
        if (count > 0) {
          badge.classList.remove('hidden')
          badge.textContent = count > 9 ? '9+' : String(count)
        } else {
          badge.classList.add('hidden')
        }
      } catch { badge.classList.add('hidden') }
    }
    update()
    window.addEventListener('njy-cart-update', update)
  }
</script>
