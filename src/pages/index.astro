---
import Layout from '@/layouts/Layout.astro'
import ProductGrid from '@/components/ProductGrid.astro'
import { getCollection } from 'astro:content'

const productos = await getCollection('productos')
const destacados = productos.filter(p => p.data.destacado)
const categorias = [...new Set(productos.map(p => p.data.categoria))]
---

<Layout title="N&J Accesorios y Belleza - Detalles que te hacen brillar">
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-b from-rose-50 to-cream-100 pt-8 md:pt-16 pb-12 md:pb-20">
    <div class="container-main text-center">
      <div class="max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-1.5 bg-rose-100 text-rose-700 text-xs font-medium px-3 py-1 rounded-full mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-gold-500 animate-pulse"></span>
          Nueva Colección 2026
        </div>
        <h1 class="font-display text-4xl md:text-6xl lg:text-7xl text-rose-800 leading-tight mb-4">
          Detalles que te
          <span class="text-gold-500 block md:inline">hacen brillar</span>
        </h1>
        <p class="font-script text-xl md:text-2xl text-gold-600 mb-6">N&J Accesorios y Belleza</p>
        <p class="text-[#2D2D2D]/70 text-sm md:text-base max-w-xl mx-auto mb-8">
          Descubre nuestra colección de accesorios y belleza. Collares, anillos, labiales y más,
          cuidadosamente seleccionados para ti.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="/productos" class="btn-primary text-sm no-underline inline-flex items-center gap-2">
            Ver Catálogo
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="https://wa.me/526181578134" target="_blank" rel="noopener noreferrer" class="btn-outline text-sm no-underline inline-flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Escríbenos
          </a>
        </div>
      </div>
    </div>

    <!-- Decorative elements -->
    <div class="absolute top-10 left-10 w-20 h-20 rounded-full bg-rose-200/30 blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-32 h-32 rounded-full bg-gold-300/20 blur-3xl"></div>
  </section>

  <!-- Categorías -->
  <section class="py-10 md:py-14">
    <div class="container-main">
      <h2 class="section-title mb-8">Categorías</h2>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/productos" class="px-5 py-2.5 rounded-full bg-white border border-rose-100 text-sm font-medium text-[#2D2D2D] hover:bg-rose-50 hover:border-rose-200 transition-colors no-underline shadow-sm">
          Todas
        </a>
        {categorias.map(cat => (
          <a
            href={`/productos?categoria=${cat}`}
            class="px-5 py-2.5 rounded-full bg-white border border-rose-100 text-sm font-medium text-[#2D2D2D] hover:bg-rose-50 hover:border-rose-200 transition-colors no-underline capitalize shadow-sm"
          >
            {cat === 'collares' && '📿 '}
            {cat === 'anillos' && '💍 '}
            {cat === 'labiales' && '💄 '}
            {cat}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Productos Destacados -->
  {destacados.length > 0 && (
    <section class="py-10 md:py-14 bg-white/50">
      <div class="container-main">
        <h2 class="section-title mb-8">✨ Productos Destacados</h2>
        <ProductGrid productos={destacados} />
        <div class="text-center mt-8">
          <a href="/productos" class="btn-outline text-sm no-underline inline-flex items-center gap-2">
            Ver todos los productos
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Instagram -->
  <section class="py-10 md:py-14">
    <div class="container-main text-center">
      <h2 class="section-title mb-2">Síguenos en Instagram</h2>
      <p class="font-script text-lg text-gold-600 mb-6">@accesoriosnyv</p>
      <a href="https://instagram.com/accesoriosnyv" target="_blank" rel="noopener noreferrer" class="btn-gold text-sm no-underline inline-flex items-center gap-2">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        @accesoriosnyv
      </a>
    </div>
  </section>
</Layout>
