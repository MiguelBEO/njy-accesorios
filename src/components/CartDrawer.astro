---

---

<div id="cart-overlay" class="fixed inset-0 bg-black/40 z-[60] opacity-0 pointer-events-none transition-opacity duration-300"></div>

<div id="cart-drawer" class="fixed bottom-0 left-0 right-0 md:right-0 md:left-auto md:top-0 md:w-[400px] z-[70] bg-cream-100 rounded-t-2xl md:rounded-none md:rounded-l-2xl shadow-2xl transform translate-y-full md:translate-x-full md:translate-y-0 transition-transform duration-300 ease-out max-h-[85vh] md:max-h-full flex flex-col">
  <div class="flex items-center justify-between px-5 py-4 border-b border-rose-100 shrink-0">
    <h2 class="font-display text-lg text-rose-800">🛍️ Mi Carrito</h2>
    <button id="cart-close-btn" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-rose-50 transition-colors bg-transparent border-none cursor-pointer" aria-label="Cerrar carrito">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#8B3A4F" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <div id="cart-items" class="flex-1 overflow-y-auto px-5 py-4 space-y-3">
    <p class="text-center text-rose-300 mt-8 text-sm">Tu carrito está vacío 💕</p>
    <p class="text-center text-xs text-rose-200">Explora nuestro catálogo y agrega productos</p>
  </div>

  <div id="cart-footer" class="hidden border-t border-rose-100 px-5 py-4 space-y-3 shrink-0">
    <div class="flex justify-between items-center">
      <span class="text-sm text-[#2D2D2D] font-medium">Total:</span>
      <span id="cart-total" class="font-display text-xl text-rose-800 font-semibold">$0 MXN</span>
    </div>
    <div class="space-y-2">
      <input id="cart-cliente" type="text" placeholder="Tu nombre (opcional)" class="w-full px-4 py-2.5 rounded-xl border border-rose-200 bg-white text-sm placeholder:text-rose-300 focus:outline-none focus:border-rose-400 focus:ring-1 focus:ring-rose-200" />
      <input id="cart-telefono" type="tel" placeholder="Tu teléfono (opcional)" class="w-full px-4 py-2.5 rounded-xl border border-rose-200 bg-white text-sm placeholder:text-rose-300 focus:outline-none focus:border-rose-400 focus:ring-1 focus:ring-rose-200" />
      <button id="cart-checkout-btn" class="btn-gold w-full flex items-center justify-center gap-2 text-sm">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Enviar pedido por WhatsApp
      </button>
      <button id="cart-clear-btn" class="w-full text-center text-xs text-rose-300 hover:text-rose-500 transition-colors bg-transparent border-none cursor-pointer">
        Vaciar carrito
      </button>
    </div>
  </div>
</div>

<script>
  const WA_NUMBER = '526181578134'

  function getCart() {
    try { return JSON.parse(localStorage.getItem('njy-cart') || '[]') } catch { return [] }
  }

  function saveCart(items) {
    localStorage.setItem('njy-cart', JSON.stringify(items))
    window.dispatchEvent(new CustomEvent('njy-cart-update'))
  }

  function renderCart() {
    const items = getCart()
    const container = document.getElementById('cart-items')
    const footer = document.getElementById('cart-footer')
    const totalEl = document.getElementById('cart-total')

    if (items.length === 0) {
      container.innerHTML = `
        <p class="text-center text-rose-300 mt-8 text-sm">Tu carrito está vacío 💕</p>
        <p class="text-center text-xs text-rose-200">Explora nuestro catálogo y agrega productos</p>
      `
      footer.classList.add('hidden')
      return
    }

    footer.classList.remove('hidden')
    const total = items.reduce((s, i) => s + (i.precio || 0) * (i.cantidad || 0), 0)
    totalEl.textContent = `$${total} MXN`

    container.innerHTML = items.map((item, index) => `
      <div class="flex gap-3 bg-white rounded-xl p-3 border border-rose-50" data-slug="${item.slug}">
        <img src="${item.imagen || '/images/placeholder.svg'}" alt="${item.title}"
             class="w-16 h-16 rounded-lg object-cover bg-rose-50" loading="lazy" />
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-[#2D2D2D] truncate">${item.title}</p>
          <p class="text-xs text-rose-500 font-semibold">$${item.precio} MXN</p>
          <div class="flex items-center gap-2 mt-1.5">
            <button class="qty-btn w-6 h-6 rounded-full bg-rose-50 hover:bg-rose-100 flex items-center justify-center text-xs font-medium text-rose-600 transition-colors border-none cursor-pointer" data-action="dec" data-index="${index}">−</button>
            <span class="text-sm font-medium w-6 text-center">${item.cantidad}</span>
            <button class="qty-btn w-6 h-6 rounded-full bg-rose-50 hover:bg-rose-100 flex items-center justify-center text-xs font-medium text-rose-600 transition-colors border-none cursor-pointer" data-action="inc" data-index="${index}">+</button>
            <button class="remove-btn ml-auto w-6 h-6 rounded-full bg-red-50 hover:bg-red-100 flex items-center justify-center text-xs text-red-400 transition-colors border-none cursor-pointer" data-index="${index}" aria-label="Eliminar">🗑️</button>
          </div>
        </div>
      </div>
    `).join('')

    container.querySelectorAll('.qty-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const index = parseInt(btn.dataset.index)
        const action = btn.dataset.action
        const cart = getCart()
        if (index >= 0 && index < cart.length) {
          if (action === 'inc') cart[index].cantidad++
          else cart[index].cantidad--
          if (cart[index].cantidad <= 0) cart.splice(index, 1)
          saveCart(cart)
          renderCart()
        }
      })
    })

    container.querySelectorAll('.remove-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const index = parseInt(btn.dataset.index)
        const cart = getCart()
        if (index >= 0 && index < cart.length) {
          cart.splice(index, 1)
          saveCart(cart)
          renderCart()
        }
      })
    })
  }

  function openDrawer() {
    const overlay = document.getElementById('cart-overlay')
    const drawer = document.getElementById('cart-drawer')
    if (!overlay || !drawer) return

    renderCart()
    overlay.classList.remove('opacity-0', 'pointer-events-none')
    overlay.classList.add('opacity-100', 'pointer-events-auto')

    drawer.classList.remove('translate-y-full', 'md:translate-x-full')
    drawer.classList.add('translate-y-0', 'md:translate-x-0')
    document.body.style.overflow = 'hidden'
  }

  function closeDrawer() {
    const overlay = document.getElementById('cart-overlay')
    const drawer = document.getElementById('cart-drawer')
    if (!overlay || !drawer) return

    overlay.classList.add('opacity-0', 'pointer-events-none')
    overlay.classList.remove('opacity-100', 'pointer-events-auto')

    drawer.classList.add('translate-y-full', 'md:translate-x-full')
    drawer.classList.remove('translate-y-0', 'md:translate-x-0')
    document.body.style.overflow = ''
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('cart-close-btn')?.addEventListener('click', closeDrawer)
    document.getElementById('cart-overlay')?.addEventListener('click', closeDrawer)

    document.addEventListener('njy-open-cart', openDrawer)

    document.getElementById('cart-checkout-btn')?.addEventListener('click', () => {
      const items = getCart()
      if (items.length === 0) return

      const nombre = (document.getElementById('cart-cliente') as HTMLInputElement)?.value || ''
      const telefono = (document.getElementById('cart-telefono') as HTMLInputElement)?.value || ''

      const lines = []
      lines.push('🛍️ *NUEVO PEDIDO - N&J Accesorios y Belleza*')
      lines.push('')
      lines.push('*Detalles que te hacen brillar* ✨')
      lines.push('')
      if (nombre) lines.push(`👤 *Cliente:* ${nombre}`)
      if (telefono) lines.push(`📱 *Teléfono:* ${telefono}`)
      if (nombre || telefono) lines.push('')
      lines.push('*Productos solicitados:*')
      let total = 0
      items.forEach((item, i) => {
        const subtotal = (item.precio || 0) * (item.cantidad || 0)
        total += subtotal
        lines.push(`${i + 1}️⃣ ${item.title} x${item.cantidad} — $${subtotal}`)
      })
      lines.push('')
      lines.push(`💰 *Total: $${total} MXN*`)
      lines.push('')
      lines.push('Quedo atenta a tu confirmación 🙌')

      const msj = encodeURIComponent(lines.join('\n'))
      window.open(`https://wa.me/${WA_NUMBER}?text=${msj}`, '_blank')
    })

    document.getElementById('cart-clear-btn')?.addEventListener('click', () => {
      saveCart([])
      renderCart()
      closeDrawer()
    })
  })
</script>
