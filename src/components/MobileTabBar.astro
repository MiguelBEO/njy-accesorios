<nav class="fixed bottom-0 left-0 right-0 z-50 bg-cream-100/95 backdrop-blur-md border-t border-rose-100 md:hidden safe-area-bottom">
  <ul class="flex items-center justify-around h-16">
    <li>
      <a href="/" class="flex flex-col items-center gap-0.5 text-[10px] font-medium text-[#2D2D2D] hover:text-rose-500 transition-colors no-underline active:text-rose-500">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span>Inicio</span>
      </a>
    </li>
    <li>
      <a href="/productos" class="flex flex-col items-center gap-0.5 text-[10px] font-medium text-[#2D2D2D] hover:text-rose-500 transition-colors no-underline active:text-rose-500">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        <span>Catálogo</span>
      </a>
    </li>
    <li>
      <button id="cart-tab-btn" class="flex flex-col items-center gap-0.5 text-[10px] font-medium text-[#2D2D2D] hover:text-rose-500 transition-colors bg-transparent border-none cursor-pointer relative active:text-rose-500" aria-label="Abrir carrito">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
        <span>Carrito</span>
        <span id="cart-tab-badge" class="absolute -top-1 -right-2 bg-gold-500 text-white text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center hidden">0</span>
      </button>
    </li>
    <li>
      <a href="https://wa.me/526181578134" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-0.5 text-[10px] font-medium text-[#2D2D2D] hover:text-rose-500 transition-colors no-underline active:text-rose-500">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        <span>WhatsApp</span>
      </a>
    </li>
    <li>
      <a href="/sobre-nosotros" class="flex flex-col items-center gap-0.5 text-[10px] font-medium text-[#2D2D2D] hover:text-rose-500 transition-colors no-underline active:text-rose-500">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        <span>Nosotros</span>
      </a>
    </li>
  </ul>
</nav>

<script>
  const tabBtn = document.getElementById('cart-tab-btn')
  if (tabBtn) {
    tabBtn.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('njy-open-cart'))
    })
  }

  const badge = document.getElementById('cart-tab-badge')
  if (badge) {
    const updateBadge = () => {
      const cart = (() => {
        try { return JSON.parse(localStorage.getItem('njy-cart') || '[]') } catch { return [] }
      })()
      const count = cart.reduce((s: number, i: any) => s + (i.cantidad || 0), 0)
      if (count > 0) {
        badge.classList.remove('hidden')
        badge.textContent = count > 9 ? '9+' : String(count)
      } else {
        badge.classList.add('hidden')
      }
    }
    updateBadge()
    window.addEventListener('njy-cart-update', updateBadge)
  }
</script>
